---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header/Header.astro"
import Footer from "../components/Footer/Footer.astro"
---

<Layout title="404 | Nomadic Digital" description="Page not found.">
	<Header />
	<section class="nf">
		<div class="nf__inner">
			<span class="nf__eyebrow">// 404</span>
			<h1 class="nf__title">Page not found.</h1>
			<p class="nf__copy">The page you're looking for doesn't exist or has moved.</p>
			<a href="/" class="nf__cta">back_home <span>→</span></a>
		</div>
	</section>
	<Footer />
</Layout>

<style>
	.nf {
		background: #0a0a0b;
		color: #f5f5f5;
		font-family: 'IBM Plex Sans', sans-serif;
		min-height: 60vh;
		display: flex;
		align-items: center;
	}
	.nf__inner {
		max-width: 1440px;
		margin: 0 auto;
		padding: clamp(64px, 10vw, 140px) clamp(20px, 4vw, 64px);
	}
	.nf__eyebrow {
		display: block;
		font-family: 'IBM Plex Mono', monospace;
		font-size: 13px;
		letter-spacing: 0.04em;
		color: #a3a3a3;
		margin-bottom: 20px;
	}
	.nf__title {
		font-family: 'Newsreader', serif;
		font-weight: 600;
		font-size: clamp(40px, 6vw, 84px);
		line-height: 1;
		letter-spacing: -0.02em;
		margin: 0 0 20px;
	}
	.nf__copy {
		font-family: 'Newsreader', serif;
		font-size: clamp(17px, 1.5vw, 20px);
		line-height: 1.55;
		color: #c4c4c4;
		margin: 0 0 36px;
		max-width: 480px;
	}
	.nf__cta {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		padding: 16px 28px;
		background: #4f46e5;
		color: #fff;
		text-decoration: none;
		font-family: 'IBM Plex Mono', monospace;
		font-size: 14px;
		font-weight: 500;
		transition: all 0.18s;
	}
	.nf__cta:hover {
		background: #4338ca;
		transform: translateY(-2px);
	}
</style>
