---
const year = new Date().getFullYear();
const links = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/matt-hall-ai-engineer-strategy-marketing" },
  { label: "GitHub", href: "https://github.com/matthall8/" },
];
---

<footer class="ft">
  <span>© 2016 - {year} Nomadic Digital · Matt Hall · AI Consultant</span>
  <div class="ft__links">
    {links.map((l) => <a class="ft__link" href={l.href}>{l.label}</a>)}
  </div>
</footer>

<style>
  .ft {
    max-width: 1440px;
    margin: 0 auto;
    padding: 30px clamp(20px, 4vw, 64px);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12.5px;
    color: #6b7280;
  }
  .ft__links { display: flex; gap: 24px; }
  .ft__link { color: #6b7280; text-decoration: none; transition: color 0.18s; }
  .ft__link:hover { color: #f5f5f5; }
</style>