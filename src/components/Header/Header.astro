---
// src/components/Header.astro
const navLinks = [
  { href: "#experience", label: "experience" },
  { href: "#services", label: "services" },
  { href: "#contact", label: "contact" },
];

import { Image } from "astro:assets";
import logo from "../../assets/nomadic-logo-final-white.png";

---

<header class="nd-header">
  <div class="nd-header__bar">
    <!-- logo -->
    <a href="#top" class="nd-logo">
          <Image class="logo" src={logo} alt="Nomadic Digital" />
    </a>

    <!-- desktop nav -->
    <nav class="nd-nav-desktop">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a href="#contact" class="nd-cta-desktop">let's_talk <span>→</span></a>

    <!-- mobile toggle -->
    <button class="nd-burger" aria-label="Toggle menu" aria-expanded="false" data-menu-toggle>
      <span></span><span></span>
    </button>
  </div>

  <!-- mobile menu -->
  <nav class="nd-menu" aria-label="Mobile" data-menu hidden>
    {navLinks.map((l) => <a href={l.href} data-menu-link>{l.label}</a>)}
    <a href="#contact" class="nd-menu__cta" data-menu-link>let's_talk →</a>
  </nav>
</header>

<style>
  .nd-header {
    position: sticky; top: 0; z-index: 60;
    background: rgba(10, 10, 11, 0.82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: #f5f5f5;
  }

  .logo {
    height: 30px;
    width: auto;
  }

  .nd-header__bar {
    max-width: 1440px; margin: 0 auto;
    padding: 18px clamp(20px, 4vw, 64px);
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .nd-logo { display: flex; align-items: center; gap: 14px; text-decoration: none; color: #f5f5f5; }

  .nd-nav-desktop { display: flex; gap: 30px; align-items: center; font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: #a3a3a3; }
  .nd-nav-desktop a { text-decoration: none; color: inherit; transition: color .18s; }
  .nd-nav-desktop a:hover { color: #f5f5f5; }

  .nd-cta-desktop {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 11px 22px; background: #4f46e5; color: #fff; text-decoration: none;
    font-family: 'IBM Plex Mono', monospace; font-size: 13px; font-weight: 500; transition: background .18s;
  }
  .nd-cta-desktop:hover { background: #4338ca; }

  .nd-burger {
    display: none; background: none; border: 1px solid rgba(255, 255, 255, 0.25);
    width: 44px; height: 44px; flex-direction: column; gap: 4px;
    align-items: center; justify-content: center; cursor: pointer; padding: 0;
  }
  .nd-burger span { display: block; width: 18px; height: 2px; background: #f5f5f5; }

  .nd-menu {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 8px clamp(20px, 5vw, 64px) 22px;
    display: flex; flex-direction: column; gap: 2px;
    font-family: 'IBM Plex Mono', monospace; font-size: 15px;
  }
  .nd-menu[hidden] { display: none; }
  .nd-menu a { text-decoration: none; color: #f5f5f5; padding: 13px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  .nd-menu__cta { color: #fff !important; background: #4f46e5; text-align: center; padding: 15px 0 !important; margin-top: 14px; border-bottom: none !important; }

  /* mobile breakpoint — matches the 860px JS switch in the original */
  @media (max-width: 859px) {
    .nd-nav-desktop, .nd-cta-desktop { display: none; }
    .nd-burger { display: flex; }
  }
  @media (min-width: 860px) {
    .nd-menu { display: none; }
  }
</style>

<script is:inline>
  function initNdHeader(header) {
    const toggle = header.querySelector('[data-menu-toggle]');
    const menu = header.querySelector('[data-menu]');
    if (!toggle || !menu || toggle.dataset.bound) return;
    toggle.dataset.bound = 'true';

    const setOpen = (open) => {
      menu.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () => setOpen(menu.hidden));
    header.querySelectorAll('[data-menu-link]').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 860) setOpen(false);
    });
  }

  document.querySelectorAll('.nd-header').forEach(initNdHeader);
</script>